---
import Layout from "../layouts/Layout.astro";
import AppShellBadge from "../components/react/AppShellBadge";
---

<Layout title="About | Web App Starter">
  <main class="container">
    <h1>About this structure</h1>
    <p>
      This route exists to show file-based routing and where a React island can live inside an
      Astro page.
    </p>
    <AppShellBadge client:load />
  </main>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
</style>

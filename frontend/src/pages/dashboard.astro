---
import MainLayout from "../layouts/MainLayout.astro";
import DashboardPanel from "../components/react/DashboardPanel";
---

<MainLayout title="Dashboard | Habit Tracker">
  <section class="panel">
    <DashboardPanel client:load />
  </section>
</MainLayout>

<style>
  .panel {
    background: #111827;
    border: 1px solid #1f2937;
    border-radius: 0.75rem;
    padding: 1.25rem;
    max-width: 800px;
  }

  h1 {
    margin-top: 0;
  }

  p {
    margin-top: 0.25rem;
    color: #94a3b8;
  }

  a {
    color: #60a5fa;
    text-decoration: none;
  }
</style>

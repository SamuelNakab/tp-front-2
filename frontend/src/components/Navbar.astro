---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<header class="navbar">
  <p>Habit Tracker Dashboard</p>
  <nav class="top-links">
    <a class={currentPath === "/" ? "active" : ""} href="/">Home</a>
    <a class={currentPath === "/dashboard" ? "active" : ""} href="/dashboard">Dashboard</a>
  </nav>
</header>

<style>
  .navbar {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    border-bottom: 1px solid #1e293b;
    background: #0f172a;
    position: sticky;
    top: 0;
  }

  p {
    margin: 0;
    color: #cbd5e1;
    font-weight: 600;
  }

  .top-links {
    display: flex;
    gap: 0.75rem;
  }

  a {
    text-decoration: none;
    color: #94a3b8;
    font-size: 0.95rem;
    padding: 0.2rem 0.45rem;
    border-radius: 0.35rem;
  }

  a:hover {
    color: #e2e8f0;
    background: #1e293b;
  }

  .active {
    color: #e2e8f0;
    background: #1e293b;
  }
</style>

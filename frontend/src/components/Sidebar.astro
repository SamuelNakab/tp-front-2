---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const links = [
  {
    href: "/",
    label: "Home",
    icon: `<path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>`,
  },
  {
    href: "/dashboard",
    label: "Dashboard",
    icon: `<path d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM2.25 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z"/>`,
  },
  {
    href: "/login",
    label: "Login",
    icon: `<path d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>`,
  },
  {
    href: "/register",
    label: "Register",
    icon: `<path d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM3 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>`,
  },
];
---

<aside class="sidebar">
  <div class="brand">Habit Tracker</div>
  <nav>
    <ul>
      {
        links.map((link) => (
          <li>
            <a class={currentPath === link.href ? "active" : ""} href={link.href}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" set:html={link.icon} />
              <span>{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    border-right: 1px solid #1e293b;
    background: #0f172a;
    padding: 1.5rem 1rem;
  }

  .brand {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: #f8fafc;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }

  a {
    display: flex !important;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: #cbd5e1;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
  }

  a svg {
    flex-shrink: 0;
    color: #94a3b8;
  }

  a:hover {
    background: #1e293b;
    color: #f8fafc;
  }

  a:hover svg {
    color: #f8fafc;
  }

  .active {
    background: #334155;
    color: #f8fafc;
  }

  .active svg {
    color: #f8fafc;
  }
</style>